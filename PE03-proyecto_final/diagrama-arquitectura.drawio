        <mxCell id="legend" value="&lt;b&gt;Flujo CI/CD:&lt;/b&gt;  Desarrollador hace &lt;font color=&quot;#e76f51&quot;&gt;&lt;b&gt;git push&lt;/b&gt;&lt;/font&gt; → Gitea notifica via &lt;font color=&quot;#457b9d&quot;&gt;&lt;b&gt;Webhook&lt;/b&gt;&lt;/font&gt; → Jenkins despliega por &lt;font color=&quot;#2a9d8f&quot;&gt;&lt;b&gt;SCP/SSH&lt;/b&gt;&lt;/font&gt; → Web actualizada en &lt;font color=&quot;#82b366&quot;&gt;&lt;b&gt;Nginx&lt;/b&gt;&lt;/font&gt;" style="text;html=1;fontSize=12;fillColor=none;align=center;verticalAlign=middle;strokeColor=none;" vertex="1" parent="1">
